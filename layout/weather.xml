      <orient>wxVERTICAL</orient>
      <object class="sizeritem">
        <object class="wxBoxSizer">
          <orient>wxHORIZONTAL</orient>
          <object class="sizeritem">
            <object class="wxButton" name="makeDayCurveAmount">
              <label>Make day curve amount</label>
              <fg>#FFFFFF</fg>
              <bg>#00397A</bg>
            </object>
            <option>0</option>
            <flag>wxALL|wxEXPAND</flag>
            <border>2</border>
          </object>
          <object class="sizeritem">
            <object class="wxButton" name="makeDayCurvePercentage">
              <label>Make day curve percentage</label>
              <fg>#FFFFFF</fg>
              <bg>#00397A</bg>
            </object>
            <option>0</option>
            <flag>wxALL|wxEXPAND</flag>
            <border>2</border>
          </object>
        </object>
        <option>0</option>
        <flag>wxLEFT|wxRIGHT|wxEXPAND</flag>
        <border>5</border>
      </object>
      <object class="sizeritem">
        <object class="wxBoxSizer">
          <orient>wxHORIZONTAL</orient>
          <object class="sizeritem">
            <object class="wxStaticText">
              <label>First year: </label>
            </object>
          </object>
          <object class="sizeritem">
            <object class="wxTextCtrl" name="firstYear">
